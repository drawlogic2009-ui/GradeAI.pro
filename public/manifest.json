{
  "manifest_version": 3,
  "name": "School Portal Pro+",
  "version": "1.0",
  "description": "AI-powered homework assistant for any school portal.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extension/content.ts"]
    }
  ],
  "background": {
    "service_worker": "src/extension/background.ts"
  }
}
