{
  "manifest_version": 3,
  "name": "GradeAI.pro",
  "version": "1.0",
  "description": "AI-powered grading assistant for teachers.",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"]
    }
  ]
}
