{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and subscription tier",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currentTier": { "type": "string", "enum": ["free", "pro", "pro+"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "currentTier", "createdAt"]
    },
    "Class": {
      "title": "Class",
      "description": "A class managed by a teacher",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "section": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "section", "teacherId", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "A student in a class",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "classId", "teacherId", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "An analysis report for a class",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "classId": { "type": "string" },
        "teacherId": { "type": "string" },
        "criteria": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "classId", "teacherId", "criteria", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A graded submission",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "classId": { "type": "string" },
        "reportId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string", "enum": ["perfect", "needs_review", "wrong"] },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "fileName": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "studentName", "classId", "reportId", "teacherId", "status", "score", "feedback", "submittedAt"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "A calendar event",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["holiday", "important"] },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "title", "type", "teacherId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/classes/{classId}": {
      "schema": { "$ref": "#/entities/Class" },
      "description": "Classes"
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Students"
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Analysis Reports"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Submissions"
    },
    "/calendarEvents/{eventId}": {
      "schema": { "$ref": "#/entities/CalendarEvent" },
      "description": "Calendar Events"
    }
  }
}
