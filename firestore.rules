rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, portalUrl, portalType
    //
    // Collection: classes
    // Fields: id, name, section, portalUrl, teacherUid
    //
    // Collection: students
    // Fields: id, name, studentId, classId, teacherUid
    //
    // Collection: homeworks
    // Fields: id, classId, title, category, questions, deadline, totalStrength, teacherUid
    //
    // Collection: submissions
    // Fields: id, homeworkId, studentId, status, feedback, teacherUid
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.teacherUid;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.teacherUid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "miragulshanarabegum@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email']) &&
             data.uid is string && data.name is string && data.email is string;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['name', 'section', 'teacherUid', 'totalStudents']) &&
             data.name is string && data.section is string && data.teacherUid is string && data.totalStudents is number;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'studentId', 'classId', 'teacherUid']) &&
             data.name is string && data.studentId is string && data.classId is string && data.teacherUid is string;
    }

    function isValidHomework(data) {
      return data.keys().hasAll(['classId', 'title', 'category', 'deadline', 'teacherUid', 'createdAt', 'totalStrength']) &&
             data.classId is string && data.title is string && data.category in ['technical', 'paragraph'] &&
             data.deadline is string && data.teacherUid is string && data.createdAt is string && data.totalStrength is number;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['homeworkId', 'studentId', 'status', 'teacherUid', 'content', 'feedback', 'submittedAt', 'studentName']) &&
             data.homeworkId is string && data.studentId is string && data.status in ['perfect', 'inaccurate', 'wrong', 'unattempted'] && data.teacherUid is string &&
             data.content is string && data.feedback is string && data.submittedAt is string && data.studentName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /classes/{classId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isRequestOwner() && isValidClass(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isRequestOwner() && isValidClass(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /students/{studentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isRequestOwner() && isValidStudent(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isRequestOwner() && isValidStudent(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /homeworks/{homeworkId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isRequestOwner() && isValidHomework(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isRequestOwner() && isValidHomework(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isRequestOwner() && isValidSubmission(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isRequestOwner() && isValidSubmission(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
